{
  "name": "@sschepis/swiss-army-tool",
  "version": "0.1.4",
  "description": "A single-tool LLM interface framework with hierarchical command routing",
  "homepage": "https://github.com/sschepis/swiss-army-tool#readme",
  "bugs": {
    "url": "https://github.com/sschepis/swiss-army-tool/issues"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sschepis/swiss-army-tool.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "llm",
    "tool",
    "cli",
    "framework",
    "ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@sschepis/swiss-army-tool": "^0.1.3"
  }
}
